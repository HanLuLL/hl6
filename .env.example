# PostgreSQL
DATABASE_URL=postgres://hl6:hl6dev@localhost:5433/hl6?sslmode=disable

# Server
SERVER_PORT=8081
# Docker Compose production image. Use the domestic GHCR proxy when required:
# HL6_IMAGE=ghcr.milu.moe/hanlull/hl6:latest
HL6_IMAGE=ghcr.io/hanlull/hl6:latest
# PostgreSQL image. Set this to an organization-approved mirror only when Docker Hub is unavailable.
POSTGRES_IMAGE=postgres:16-alpine
# DNS bulk delete threshold (when record count > threshold, switch to async bulk job)
DNS_BATCH_ASYNC_THRESHOLD=200
# First registered user is assigned admin automatically.
# Shared public URL for same-origin deployments (optional convenience alias)
APP_URL=

# Auth
# Optional seed for first startup only.
# If empty, server generates a strong secret and stores it in DB key "_internal_session_secret".
SESSION_SECRET=
# Required for email/password authentication. Generate a high-entropy value and
# keep it outside PostgreSQL. Set a previous value temporarily during rotation.
AUTH_PASSWORD_PEPPER_ID=v1
AUTH_PASSWORD_PEPPER=
AUTH_PREVIOUS_PASSWORD_PEPPER_ID=
AUTH_PREVIOUS_PASSWORD_PEPPER=
# First-start SMTP bootstrap. Values are copied only into missing database
# settings, so new installations can verify their first registration before an
# administrator account exists. Keep SMTP_BOOTSTRAP_ENABLED=false until every
# sender field is ready, and set ENCRYPTION_KEY in production to encrypt the
# copied SMTP password.
SMTP_BOOTSTRAP_HOST=
SMTP_BOOTSTRAP_PORT=587
SMTP_BOOTSTRAP_USERNAME=
SMTP_BOOTSTRAP_PASSWORD=
SMTP_BOOTSTRAP_FROM_NAME=HL6
SMTP_BOOTSTRAP_FROM_ADDR=
SMTP_BOOTSTRAP_USE_TLS=true
SMTP_BOOTSTRAP_ENABLED=false
# Runtime URL precedence:
# 1) FRONTEND_URL / BACKEND_URL (if provided)
# 2) APP_URL fallback (if per-side URL missing)
# 3) DB config (frontend_urls / backend_urls, legacy frontend_url / backend_url still supported)
# 4) Auto-detected from request and persisted to DB
# FRONTEND_URL / BACKEND_URL support multiple values, separated by comma/newline.
# Leave empty if you want DB/auto-detection mode.
BACKEND_URL=http://localhost:8081
FRONTEND_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5174

# Web (Vite reads root .env via envDir "..")
VITE_DEV_PORT=5174
# Local dev/default reverse proxy:
VITE_API_BASE_URL=/api/v1
# Cross-origin deploy example:
# VITE_API_BASE_URL=https://api.example.com/api/v1

# Encryption (optional, hex-encoded 32 bytes for AES-256-GCM; empty means plaintext storage for sensitive DB configs like Cloudflare secrets)
ENCRYPTION_KEY=

# Server-only archive storage used by guarded database export and restore.
MAINTENANCE_DATA_DIR=./data/maintenance

# Content audit (optional Redis; empty = in-process queue, fine for single-instance dev)
# REDIS_ADDR=localhost:6379
AUDIT_SCAN_INTERVAL=30m
AUDIT_SCAN_WORKER_COUNT=2
AUDIT_SCAN_TIMEOUT=15s

# 支付网关配置已迁移到后台管理（系统设置 → 支付配置），无需在 .env 中配置。
