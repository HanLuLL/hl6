# PostgreSQL
DATABASE_URL=postgres://hl6:hl6dev@localhost:5432/hl6?sslmode=disable

# Server
SERVER_PORT=8080
ADMIN_EMAILS=admin@example.com
# Shared public URL for same-origin deployments (optional convenience alias)
APP_URL=

# OIDC (compatible with any OIDC provider: Logto, Keycloak, Authentik, Google, Zitadel, etc.)
OIDC_ISSUER=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Auth
# Optional seed for first startup only.
# If empty, server generates a strong secret and stores it in DB key "_internal_session_secret".
SESSION_SECRET=
# OIDC callback base URL (set to backend public URL for split-domain deploy)
BACKEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Web (Vite reads root .env via envDir "..")
# Local dev/default reverse proxy:
VITE_API_BASE_URL=/api/v1
# Cross-origin deploy example:
# VITE_API_BASE_URL=https://api.example.com/api/v1

# Encryption (optional, hex-encoded 32 bytes for AES-256-GCM; empty means plaintext Cloudflare token storage)
ENCRYPTION_KEY=
