# PostgreSQL
DATABASE_URL=postgres://hl6:hl6dev@localhost:5432/hl6?sslmode=disable

# Server
SERVER_PORT=8080
ADMIN_EMAILS=admin@example.com

# OIDC (compatible with any OIDC provider: Logto, Keycloak, Authentik, Google, Zitadel, etc.)
OIDC_ISSUER=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Auth
SESSION_SECRET=random-32-byte-string
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Encryption (hex-encoded 32 bytes for AES-256-GCM, generate with: openssl rand -hex 32)
ENCRYPTION_KEY=
